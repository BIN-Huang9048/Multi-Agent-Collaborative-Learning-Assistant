# ============================================================
# backend/.env.example — 环境变量模板
# ============================================================
# 使用方式：
#   1. 复制本文件为 .env：  cp .env.example .env
#   2. 编辑 .env 填入真实密钥和配置
#   3. 启动服务：uvicorn app.main:app --reload
#
# 注意：
#   - .env 文件包含敏感信息，已列入 .gitignore，请勿提交到版本库
#   - 所有配置项均有默认值，未设置时服务仍可启动（使用占位符）
# ============================================================

# ---- DeepSeek API 配置 ----
# API 密钥（必填，否则 LLM 调用将失败）
DEEPSEEK_API_KEY=your-deepseek-api-key
# API 基础 URL（DeepSeek 官方端点，OpenAI 兼容协议）
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
# DeepSeek 对话模型名称
DEEPSEEK_CHAT_MODEL=deepseek-chat
# DeepSeek 向量嵌入模型名称
DEEPSEEK_EMBED_MODEL=deepseek-embed
# 生成温度（0.0=确定性，1.0=创造性，建议 0.3~0.8）
LLM_TEMPERATURE=0.7
# 单次最大输出 Token 数
LLM_MAX_TOKENS=4096
# API 请求超时（秒）
LLM_REQUEST_TIMEOUT=120

# ---- 服务配置 ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
# 调试模式（true/false）：开启后日志更详细、Swagger 文档可见
DEBUG_MODE=true

# ---- 日志配置 ----
# 日志级别：DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---- 跨域（CORS）配置 ----
# 允许的域名，多个用英文逗号分隔；设为 * 表示允许所有来源
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500

# ---- 向量库配置 ----
# ChromaDB 集合名称
VECTOR_COLLECTION_NAME=knowledge
# 默认检索 Top-K 条数
VECTOR_SEARCH_TOP_K=5

# ---- Agent 配置 ----
# Agent 自检失败最大重试次数
AGENT_MAX_RETRIES=3
